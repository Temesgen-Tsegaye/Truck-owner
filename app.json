{
  "expo": {
    "name": "Truck Owner",
    "slug": "truck-owner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/flowera-logo.png",
    "scheme": "flowera-truck-owner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.truckowner",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show your position on the map.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.truckowner",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo/flowera-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f2c063",
          "dark": {
            "backgroundColor": "#0c1438"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      ["@maplibre/maplibre-react-native", {
        "android": {
          "nativeVariant": "opengl",
          "nativeVersion": "11.12.1",
          "pluginVersion": "3.0.2",
          "turfVersion": "6.0.1",
          "okhttpVersion": "4.9.0",
          "locationEngine": "default"
        },
        "ios": {
          "nativeVersion": "11.12.1"
        }
      }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98951a30-001e-4522-9b87-0c354e00905e"
      }
    }
  }
}
