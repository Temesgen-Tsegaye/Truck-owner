{
  "expo": {
    "name": "Truck Owner",
    "slug": "truck-owner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/flowera-logo.png",
    "scheme": "flowera-truck-owner",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.truckowner",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show your position on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location in the background to provide location-based services.",
        "NSUserNotificationsUsageDescription": "This app needs to send you notifications about your deliveries and updates.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location",
          "remote-notification",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.truckowner",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@maplibre/maplibre-react-native",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo/flowera-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f2c063",
          "dark": {
            "backgroundColor": "#0c1438"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-build-properties",
      "expo-task-manager",
      "expo-background-fetch",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98951a30-001e-4522-9b87-0c354e00905e"
      }
    },
    "owner": "hailehaile"
  }
}
